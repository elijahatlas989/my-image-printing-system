@model Order

@{
    ViewData["Title"] = "Order Summary";
}

<section class="page-header">
    <span class="hero-badge">
        Step 3
    </span>

    <h1>Order summary</h1>

    <p>
        Check the selected size, quantity, unit price and grand total.
    </p>
</section>

@if (Model == null)
{
    <div class="alert alert-danger">
        Order information could not be loaded.
    </div>
}
else
{
    <section class="pb-5">
        <div class="card">
            <div class="card-body p-4">

                <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
                    <div>
                        <small class="text-muted d-block">
                            Purchase Order
                        </small>

                        <h2 class="mb-0">
                            #@Model.OrderId.ToString("D4")
                        </h2>
                    </div>

                    <span class="badge rounded-pill text-bg-primary p-3">
                        @Model.Status
                    </span>
                </div>

                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead>
                            <tr>
                                <th>Photo</th>
                                <th>Size</th>
                                <th>Quantity</th>
                                <th>Unit Price</th>
                                <th>Total</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (OrderDetail item in Model.OrderDetails)
                            {
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            <img src="/uploads/@Model.FolderName/@item.StoredFileName"
                                                 alt="@item.OriginalFileName"
                                                 style="width:68px;height:68px;object-fit:cover;border-radius:12px;" />

                                            <span>
                                                @item.OriginalFileName
                                            </span>
                                        </div>
                                    </td>

                                    <td>
                                        @item.PrintSize.SizeName
                                    </td>

                                    <td>
                                        @item.Quantity
                                    </td>

                                    <td>
                                        Rs. @item.Price.ToString("N2")
                                    </td>

                                    <td>
                                        <strong>
                                            Rs. @item.LineTotal.ToString("N2")
                                        </strong>
                                    </td>
                                </tr>
                            }
                        </tbody>

                        <tfoot>
                            <tr>
                                <th colspan="4"
                                    class="text-end">
                                    Grand Total
                                </th>

                                <th class="fs-5 text-primary">
                                    Rs. @Model.TotalAmount.ToString("N2")
                                </th>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                <div class="d-flex justify-content-end flex-wrap gap-2 mt-4">
                    <a asp-action="SelectPrints"
                       asp-route-orderId="@Model.OrderId"
                       class="btn btn-outline-primary btn-lg">
                        Change Size
                    </a>

                    <a asp-action="Payment"
                       asp-route-orderId="@Model.OrderId"
                       class="btn btn-primary btn-lg">
                        Continue to Payment
                    </a>
                </div>
            </div>
        </div>
    </section>
}
