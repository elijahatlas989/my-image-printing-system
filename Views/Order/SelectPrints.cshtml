@model SelectPrintsViewModel

@{
    ViewData["Title"] = "Select Prints";
}

<section class="page-header">
    <span class="hero-badge">
        Step 2
    </span>

    <h1>Select size and quantity</h1>

    <p>
        Choose the print size and number of copies for every uploaded photograph.
    </p>
</section>

@if (Model == null || Model.Items == null || Model.Items.Count == 0)
{
    <div class="card">
        <div class="card-body p-5 text-center">
            <h2>No photos found</h2>

            <a asp-action="UploadPhotos"
               class="btn btn-primary">
                Upload Photos
            </a>
        </div>
    </div>
}
else
{
    <form asp-action="SelectPrints" method="post">
        <input asp-for="OrderId" type="hidden" />

        <div asp-validation-summary="ModelOnly"
             class="alert alert-danger">
        </div>

        <div class="row g-4">
            @for (int i = 0; i < Model.Items.Count; i++)
            {
                <div class="col-md-6 col-xl-4">
                    <div class="card feature-card h-100">
                        <img src="@Model.Items[i].ImageUrl"
                             alt="@Model.Items[i].OriginalFileName"
                             style="width:100%;height:250px;object-fit:cover;" />

                        <div class="card-body">
                            <h3 class="h6 text-truncate mb-3">
                                @Model.Items[i].OriginalFileName
                            </h3>

                            <input asp-for="Items[i].DetailId"
                                   type="hidden" />

                            <div class="mb-3">
                                <label asp-for="Items[i].PrintSizeId"
                                       class="form-label">
                                </label>

                                <select asp-for="Items[i].PrintSizeId"
                                        asp-items="Model.PrintSizes"
                                        class="form-select">
                                </select>
                            </div>

                            <div>
                                <label asp-for="Items[i].Quantity"
                                       class="form-label">
                                </label>

                                <input asp-for="Items[i].Quantity"
                                       class="form-control"
                                       min="1"
                                       max="100" />
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="card mt-4">
            <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <strong>Next step:</strong>
                    calculate the price using the selected database rates.
                </div>

                <button type="submit"
                        class="btn btn-primary btn-lg">
                    Calculate Total Price
                </button>
            </div>
        </div>
    </form>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
