@model IEnumerable<PrintSize>

@{
    ViewData["Title"] = "Print Sizes";
    var sizes = Model?.ToList() ?? new List<PrintSize>();
}

<section class="page-header">
    <span class="hero-badge">Administrator</span>
    <h1>Print Sizes and Prices</h1>
    <p>Add new photo-printing sizes or remove unused options from the database.</p>
</section>

<section class="pb-5">
    <div class="row g-4">
        <div class="col-lg-5">
            <div class="card h-100">
                <div class="card-body p-4 p-lg-5">
                    <div class="display-4 mb-3">➕</div>
                    <h2 class="h3">Add Print Size</h2>
                    <p class="text-muted">
                        Enter a display name and price for the new size.
                    </p>

                    <form asp-action="AddPrintSize" method="post">
                        <div class="mb-3">
                            <label class="form-label">Size Name</label>
                            <input name="SizeName"
                                   class="form-control"
                                   placeholder="Example: 12 x 18"
                                   required />
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Price</label>
                            <input name="Price"
                                   type="number"
                                   step="0.01"
                                   min="1"
                                   class="form-control"
                                   placeholder="Enter price"
                                   required />
                        </div>

                        <button class="btn btn-primary"
                                type="submit">
                            Add Print Size
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="card h-100">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <div>
                            <h2 class="h3 mb-1">Available Sizes</h2>
                            <p class="text-muted mb-0">@sizes.Count size(s) available</p>
                        </div>

                        <div class="display-5">🖼️</div>
                    </div>

                    @if (sizes.Count == 0)
                    {
                        <div class="alert alert-danger">
                            No print sizes are currently available.
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table align-middle">
                                <thead>
                                    <tr>
                                        <th>Size</th>
                                        <th>Price</th>
                                        <th class="text-end">Action</th>
                                    </tr>
                                </thead>

                                <tbody>
                                    @foreach (var size in sizes)
                                    {
                                        <tr>
                                            <td><strong>@size.SizeName</strong></td>
                                            <td>Rs. @size.Price.ToString("N2")</td>
                                            <td class="text-end">
                                                <form asp-action="DeletePrintSize"
                                                      method="post"
                                                      class="d-inline">
                                                    <input type="hidden"
                                                           name="id"
                                                           value="@size.PrintSizeId" />

                                                    <button class="btn btn-sm btn-outline-danger"
                                                            type="submit">
                                                        Delete
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>
